%%

bool flag = false;

%%

Start =
     (v:SkipUntil SkipUntil)
  / (v:SkipTil SkipTil)
  / (v:TakeUntil TakeUntil)
  / (v:TakeTil TakeTil)
  / (v:AndPredicateAction AndPredicateAction)
  / (v:OrderedChoiceWithLiterals OrderedChoiceWithLiterals)
  / (v:OrderedChoiceWithLiterals OrderedChoiceWithLiterals)
  / (v:Verify41 Verify41)
  / (v:VerifyFlag VerifyFlag)
  ;

AndPredicateAction = &{ flag ? true : state.fail(const ErrorMessage(0, 'error')) }  v:Integer ;

int
Integer = v:$[0-9]+ <int>{ $$ = int.parse(v); } ;

OrderedChoiceWithLiterals =
    'abc'
  / 'ab'
  / 'a'
  / 'def'
  / 'de'
  / 'd'
  / 'gh'
  ;

SkipUntil =  (!'END'  v:.)* ;

SkipTil =  (![E]  v:.)* ;

TakeTil =  $(![E]  v:.)* ;

TakeUntil =  $(!'END'  v:.)* ;

Verify41 = @verify(Integer, {
    if ($$ != 41) { state.failAt(state.failPos, ErrorMessage(pos - state.failPos, 'error')); }
  }) ;

VerifyFlag = @verify('', {
    if (!flag) { state.failAt(state.failPos, ErrorMessage(pos - state.failPos, 'error')); }
  }) ;